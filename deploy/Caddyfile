# Caddy: automatic HTTPS (Let's Encrypt) in front of Bilson AI.
# Install: sudo cp deploy/Caddyfile /etc/caddy/Caddyfile  (then set your domain)
#
# The Bilson AI app handles its own auth (sessions for the site, API keys for
# /v1/*), so Caddy here just terminates TLS and proxies. Replace your.domain.example.
your.domain.example {
    encode gzip
    # The Bilson AI app serves everything on :8001 — the website, the REST API,
    # and the MCP endpoint at /mcp (all authenticated by the app itself). Caddy
    # just terminates TLS and proxies. Set BILSON_PUBLIC_URL=https://your.domain
    # in the service so the dashboard shows the right /mcp URL.
    reverse_proxy 127.0.0.1:8001
}
