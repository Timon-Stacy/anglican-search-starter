# HOME app config. Copy to `.env` and fill in. Never commit the real .env.

# --- Bilson AI website / accounts -----------------------------------------
# REQUIRED: a stable session secret. Generate with: openssl rand -hex 32
BILSON_SECRET=CHANGE_ME_openssl_rand_hex_32
# This email becomes admin when it signs up (or use the admin CLI later).
BILSON_ADMIN_EMAIL=you@example.com
# Public URL the dashboard shows for the MCP endpoint. Your real domain.
BILSON_PUBLIC_URL=https://library.example.com
# Accounts/keys/usage DB (kept on the mounted data volume).
BILSON_DB=/data/accounts.db
# Per-user monthly request quota (override per-user in the admin panel).
BILSON_MONTHLY_LIMIT=1000

# --- Search engine ---------------------------------------------------------
# Pin the Arc GPU. (cuda/cpu also valid; the engine auto-detects otherwise.)
ANGLICAN_DEVICE=xpu
# Repaired library DB + index on the data volume.
ANGLICAN_DB=/data/library.db
ANGLICAN_INDEX=/data/index.faiss
# Full cross-encoder reranker is fine on the Arc GPU.
ANGLICAN_RERANKER=BAAI/bge-reranker-v2-m3
ANGLICAN_RERANK_POOL=80

# --- Build arg -------------------------------------------------------------
# Intel Extension-for-PyTorch base image tag (verify the current "-xpu" tag at
# https://hub.docker.com/r/intel/intel-extension-for-pytorch/tags ).
IPEX_TAG=2.7.10-xpu

# Timezone for the wireguard container (cosmetic).
TZ=Etc/UTC
