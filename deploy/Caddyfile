# Caddy: automatic HTTPS (Let's Encrypt) in front of Bilson AI.
# Install: sudo cp deploy/Caddyfile /etc/caddy/Caddyfile  (then set your domain)
#
# The Bilson AI app handles its own auth (sessions for the site, API keys for
# /v1/*), so Caddy here just terminates TLS and proxies. Replace your.domain.example.
your.domain.example {
    encode gzip

    # Optional: also expose the MCP endpoint, gated by a Bilson API key.
    # Requires the separate anglican-mcp service running on :8000 (extra ~6 GB RAM).
    # handle /mcp* {
    #     forward_auth 127.0.0.1:8001 {
    #         uri /v1/verify
    #         copy_headers Authorization
    #     }
    #     reverse_proxy 127.0.0.1:8000 {
    #         flush_interval -1
    #     }
    # }

    # Website + REST API -> the Bilson AI app.
    reverse_proxy 127.0.0.1:8001
}
