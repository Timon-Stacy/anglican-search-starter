# VPS peer (the listening side, has the public IP). Copy to wg0.conf and fill in.
# Generate this box's keys:  wg genkey | tee vps.key | wg pubkey > vps.pub
# Put vps.pub into the HOME wg0.conf as the peer PublicKey, and paste the home
# box's public key below.
[Interface]
Address = 10.8.0.1/24
ListenPort = 51820
PrivateKey = <VPS_PRIVATE_KEY>

[Peer]
# The home server (Arc box). It dials in, so no Endpoint here.
PublicKey = <HOME_PUBLIC_KEY>
AllowedIPs = 10.8.0.2/32
